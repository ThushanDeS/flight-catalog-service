# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=flight_db
MONGO_USER=
MONGO_PASSWORD=

# Service Configuration
PORT=5001
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Other Service URLs (for when this service calls others)
